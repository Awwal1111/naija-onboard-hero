{
  "name": "NaijaLancers - Connect, Earn & Grow",
  "short_name": "NaijaLancers",
  "description": "Nigeria's trusted freelance marketplace connecting verified experts with clients. Hire skilled freelancers or earn online with secure payments.",
  "start_url": "/main-feed",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone", "minimal-ui"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "background_color": "#ffffff",
  "theme_color": "#10b981",
  "orientation": "any",
  "dir": "ltr",
  "lang": "en",
  "id": "/main-feed",
  "scope": "/",
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=co.median.android.mbbeeqr",
      "id": "co.median.android.mbbeeqr"
    }
  ],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/logo.png",
      "sizes": "1024x1024",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "categories": ["social", "business", "productivity"],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "share_target": {
    "action": "/main-feed",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+naijalancers",
      "url": "/main-feed?ref=%s"
    }
  ],
  "scope_extensions": [
    { "origin": "https://naijalancers.name.ng" },
    { "origin": "https://naijalancers.lovable.app" }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/main-feed",
      "accept": {
        "application/pdf": [".pdf"],
        "image/*": [".png", ".jpg", ".jpeg", ".gif", ".webp"],
        "text/plain": [".txt"]
      }
    }
  ],
  "handle_links": "preferred",
  "note_taking": {
    "new_note_url": "/main-feed"
  },
  "widgets": [
    {
      "name": "NaijaLancers Feed",
      "description": "Quick access to your feed",
      "tag": "naijalancers-widget",
      "ms_ac_template": "feed",
      "screenshots": [
        { "src": "/screenshot-narrow.jpg", "sizes": "540x720", "type": "image/jpeg" }
      ]
    }
  ],
  "shortcuts": [
    {
      "name": "Find Experts",
      "short_name": "Experts",
      "url": "/experts",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Post a Job",
      "short_name": "Post Job",
      "url": "/post-job",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Messages",
      "short_name": "Chat",
      "url": "/messaging",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshot-narrow.jpg",
      "sizes": "540x720",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "NaijaLancers - Nigeria's Freelance Platform"
    },
    {
      "src": "/screenshot-wide.jpg",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "NaijaLancers - Desktop View"
    }
  ]
}
